# Claude API — required for the interview + VSL generation
ANTHROPIC_API_KEY=your_api_key_here

# Brain vault reads (live promo intelligence). GitHub PAT with repo read.
# When unset locally, brain-reader falls back to BRAIN_DIR on the filesystem.
GITHUB_TOKEN=
BRAIN_GITHUB_REPO=stephenpriorhub/brain
BRAIN_DIR=/Users/stephenprior/github/brain

# Promo Analyzer (real comparable-promo results). Walled behind hub auth, so
# Promo Builder calls it server-to-server with the shared service token.
PROMO_ANALYZER_URL=https://promo.oxfordhub.app
HUB_API_TOKEN=

# OxfordHub identity resolution (/api/me) for project ownership.
HUB_URL=https://oxfordhub.app

# Server-side project store (Railway volume mount). Falls back to ./data locally.
DATA_DIR=/app/data
